<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tentang Layanan Desa"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/bina_desa_blue"/>

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="@color/bina_desa_blue" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Program Bina Desa hadir untuk mewujudkan tata kelola administrasi desa yang lebih modern dan transparan melalui dua pilar utama:"
            android:textSize="16sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Layanan Mandiri"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/bina_desa_blue"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Memberikan akses penuh kepada warga untuk melihat data kependudukan secara mandiri, memantau status bantuan, serta memperbarui informasi profil tanpa harus melalui proses birokrasi yang rumit."
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Administrasi Surat"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/bina_desa_blue"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Digitalisasi permohonan surat menyurat seperti Surat Pengantar, Surat Keterangan Tidak Mampu (SKTM), hingga Surat Domisili. Warga cukup mengajukan lewat aplikasi dan mengambil surat yang sudah jadi di kantor desa."
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="Dibuat untuk Indonesia yang lebih Digital."
            android:textSize="12sp"
            android:textColor="#999999"
            android:textStyle="italic"/>

    </LinearLayout>
</ScrollView>