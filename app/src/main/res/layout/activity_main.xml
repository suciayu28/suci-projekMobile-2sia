<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"> <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbarMain"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@android:color/transparent"
    app:title="Dashboard Bina Desa"
    app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_below="@id/toolbarMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="30dp">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Halo, Selamat Datang"
                android:textSize="16sp"
                android:textColor="#B3FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Layanan Mandiri Desa"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="32dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#F2FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="MENU UTAMA"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/bina_desa_text_gray"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/btnWebView"
                        android:text="Web View Bina Desa"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/bina_desa_blue"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnRumus"
                        android:text="Rumus Bangun Ruang"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:backgroundTint="#4A90E2"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btnCustom1"
                            android:layout_weight="1"
                            android:text="Custom 1"
                            android:textAllCaps="false"
                            app:cornerRadius="12dp"
                            android:backgroundTint="#5C6BC0"
                            android:layout_marginEnd="6dp"
                            android:layout_width="0dp"
                            android:layout_height="60dp"/>

                        <Button
                            android:id="@+id/btnCustom2"
                            android:layout_weight="1"
                            android:text="Custom 2"
                            android:textAllCaps="false"
                            app:cornerRadius="12dp"
                            android:backgroundTint="#5C6BC0"
                            android:layout_marginStart="6dp"
                            android:layout_width="0dp"
                            android:layout_height="60dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnLogout"
                android:text="Keluar Akun"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="12dp"
                android:backgroundTint="#E53935"
                android:layout_marginTop="32dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconGravity="textStart"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>